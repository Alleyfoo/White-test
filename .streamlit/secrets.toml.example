# White Mushroom Test — Streamlit secrets example.
#
# Copy to .streamlit/secrets.toml (gitignored) and fill in. The app reads the
# [llm] section and merges it BELOW the live ⚙ Model popover choices (the
# popover wins), so this file is mainly for persistence — e.g. an API key that
# should survive a page refresh or a Streamlit Community Cloud redeploy where
# the popover's password field (session-only) would be lost.
#
# For local Ollama you can usually leave this empty: the popover's host/model
# choices are enough. For OpenAI, put your key here so it persists.

[llm]
# provider = "openai"                       # ollama | openai
# model = "gpt-4o"                          # e.g. "gpt-4o" (openai) or "qwen3.5:9b" (ollama)
# api_key = "sk-..."                        # openai only
# host = "http://localhost:11434"           # ollama only
# base_url = "https://api.openai.com/v1"    # openai only