# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
.pytest_cache/
.coverage
htmlcov/
.tox/

# Virtual environments
.venv/
venv/
env/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local artefacts
*.log
.env
.env.*
*.swp
*~

# v0.2 image manifest: filenames are committed in the manifest, but
# the actual image files are not. Downstream users add them locally.
data/images/*.jpg
data/images/*.jpeg
data/images/*.png
data/images/*.webp

# v0.4: local Ollama runner image dir. The runner expects the user to
# point --image-dir at a directory they populate with the 14 image
# files referenced by data/images/manifest.jsonl. The placeholders
# used for smoke runs live here and are not committed.
data/images/local/

# v0.9: local LLM config + Streamlit secrets. Examples are committed
# (config.yaml.example, .streamlit/secrets.toml.example); the real files
# hold API keys / host choices and must never be committed.
config.yaml
.streamlit/secrets.toml

# Raw model outputs (run-ollama / probe / edibility): never commit. The
# committed sample_manual_outputs.jsonl is already tracked, so this pattern
# only keeps generated run/edibility outputs out of `git status`.
data/model_outputs/*.jsonl
